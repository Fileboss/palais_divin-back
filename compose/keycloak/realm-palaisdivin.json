{
  "realm": "palaisdivin",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      { "name": "USER", "description": "Standard user (RBAC level 2)" },
      { "name": "ADMIN", "description": "Administrator (RBAC level 3)" }
    ]
  },
  "clients": [
    {
      "clientId": "palais-divin-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "palais-divin-backend",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "test-backend-secret"
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@palaisdivin.lepgu.fr",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "testpassword", "temporary": false }
      ],
      "realmRoles": ["USER"]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "testadmin",
      "enabled": true,
      "emailVerified": true,
      "email": "testadmin@palaisdivin.lepgu.fr",
      "firstName": "Test",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "testadmin", "temporary": false }
      ],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "service-account-palais-divin-backend",
      "enabled": true,
      "serviceAccountClientId": "palais-divin-backend",
      "clientRoles": {
        "realm-management": ["realm-admin"]
      }
    }
  ]
}
